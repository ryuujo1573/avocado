{
  "name": "@avocado/core",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "seed": "bun src/prisma/seed.ts",
    "db:push": "prisma db push --schema src/prisma/schema.prisma --accept-data-loss"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./qos": {
      "import": "./src/qos.ts",
      "types": "./src/qos.ts"
    },
    "./protocol": {
      "import": "./src/protocol/index.ts",
      "types": "./src/protocol/index.ts"
    },
    "./machines": {
      "import": "./src/machines/index.ts",
      "types": "./src/machines/index.ts"
    },
    "./ports": {
      "import": "./src/ports.ts",
      "types": "./src/ports.ts"
    },
    "./orm/*": "./src/prisma/generated/client/*",
    "./orm": {
      "require": {
        "node": "./src/prisma/generated/client/index.js",
        "edge-light": "./src/prisma/generated/client/wasm.js",
        "workerd": "./src/prisma/generated/client/wasm.js",
        "worker": "./src/prisma/generated/client/wasm.js",
        "browser": "./src/prisma/generated/client/index-browser.js",
        "default": "./src/prisma/generated/client/index.js"
      },
      "import": {
        "node": "./src/prisma/generated/client/index.js",
        "edge-light": "./src/prisma/generated/client/wasm.js",
        "workerd": "./src/prisma/generated/client/wasm.js",
        "worker": "./src/prisma/generated/client/wasm.js",
        "browser": "./src/prisma/generated/client/index-browser.js",
        "default": "./src/prisma/generated/client/index.js"
      },
      "default": "./index.js"
    }
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/bun": "^1.1.1",
    "@types/node": "20",
    "prisma": "^5.14.0",
    "rollup": "^4.17.2",
    "typescript": "5.4.4",
    "vite": "^5.2.10",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "xstate": "^5.0.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "bun src/prisma/seed.ts"
  }
}
